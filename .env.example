# ─── LLM Configuration ─────────────────────────────────────────────────────────
# Google Gemini (FREE — preferred)
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-1.5-flash

# Groq (FREE fallback — Llama 3 models)
# Get your key at: https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3-70b-8192

# ─── Auth ───────────────────────────────────────────────────────────────────────
# Change this to a long random string in production
JWT_SECRET=logosgotham-dev-secret-2026-hackathon-change-in-prod

# ─── Demo Users ────────────────────────────────────────────────────────────────
# Seller: username=seller  password=seller123  (role=seller)
# Buyer:  username=buyer   password=buyer123   (role=buyer)

# ─── Signal Poll Settings ──────────────────────────────────────────────────────
SIGNAL_POLL_INTERVAL_SECONDS=30
AUTONOMOUS_CHECK_LEAD_MINUTES=30
