# ─── LLM Configuration ─────────────────────────────────────────────────────────
# Google Gemini (FREE — preferred)
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Groq (FREE fallback — Llama 3 models)
# Get your key at: https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3-70b-8192

# ─── Auth ───────────────────────────────────────────────────────────────────────
# Change this to a long random string in production
JWT_SECRET=logosgotham-dev-secret-2026-hackathon-change-in-prod

# ─── Layer 1 Source APIs ───────────────────────────────────────────────────────
# NewsAPI
NEWSAPI_KEY=

# Mappls / MapmyIndia traffic
MAPPLS_CLIENT_ID=
MAPPLS_CLIENT_SECRET=

# Mappls / MapmyIndia routing
MAPPLS_REST_API_KEY=

# GoComet ports
GOCOMET_API_KEY=

# OpenRouteService fallback routing
OPENROUTESERVICE_API_KEY=

# Optional event stream backend
REDIS_URL=redis://localhost:6379

# ─── Demo Users ────────────────────────────────────────────────────────────────
# Admin:    username=admin     password=admin123     (role=admin)
# Seller:   username=seller    password=seller123    (role=seller)
# Receiver: username=receiver  password=receiver123  (role=receiver)
# Buyer alias remains supported and maps to receiver role.

# ─── Signal Poll Settings ──────────────────────────────────────────────────────
SIGNAL_POLL_INTERVAL_SECONDS=30
AUTONOMOUS_CHECK_LEAD_MINUTES=30
